plugins {
    id("com.android.application")
}

val melodyRoot = File("{{MELODY_ROOT}}")
val appOverrides = File("{{APP_OVERRIDE_DIR}}")

android {
    namespace = "{{NAMESPACE}}"
    compileSdk = {{COMPILE_SDK}}

    defaultConfig {
        applicationId = "{{APPLICATION_ID}}"
        minSdk = {{MIN_SDK}}
        targetSdk = {{TARGET_SDK}}
        versionCode = {{VERSION_CODE}}
        versionName = "{{VERSION_NAME}}"
    }

    compileOptions {
        sourceCompatibility = JavaVersion.VERSION_17
        targetCompatibility = JavaVersion.VERSION_17
    }

    sourceSets {
        getByName("main") {
            manifest.srcFile(File(appOverrides, "app/src/main/AndroidManifest.xml"))
            java.srcDirs(
                File(appOverrides, "app/src/main/java"),
{{MODULE_JAVA_SRCDIRS}}
            )
            res.srcDirs(File(appOverrides, "app/src/main/res"))
            jniLibs.srcDirs("src/main/jniLibs")
        }
    }
}
