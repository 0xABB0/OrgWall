; KFM's constants and state file.
; There are comments scattered through this file, so you may like to
; take a look if would like to learn more about the cns.

[Data]
;Amount of life to start with
life = 1000
;attack power (more is stronger)
attack = 100
;defensive power (more is stronger)
defence = 100
;Percentage to increase defense everytime player is knocked down
fall.defence_up = 50
;Time which player lies down for, before getting up
liedown.time = 60
;Number of points for juggling
airjuggle = 15
;Default hit spark number for HitDefs
sparkno = 0
;Default guard spark number
guard.sparkno = 40
;1 to enable echo on KO
KO.echo = 0
;Volume offset (negative for softer)
volume = 150
;Variables with this index and above will not have their values
;reset to 0 between rounds or matches. There are 60 int variables,
;indexed from 0 to 59, and 40 float variables, indexed from 0 to 39.
;If omitted, then it defaults to 60 and 40 for integer and float
;variables repectively, meaning that none are persistent, i.e. all
;are reset. If you want your variables to persist between matches,
;you need to override state 5900 from common1.cns.
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 0.93;0.83*1.12 ;Horizontal scaling factor.
yscale = 1.20;1.07*1.12 ;Vertical scaling factor.
ground.back = 18     ;Player width (back, ground)
ground.front = 19    ;Player width (front, ground)
air.back = 15        ;Player width (back, air)
air.front = 15       ;Player width (front, air)
height = 50          ;Height of player (for opponent to jump over)
attack.dist = 160    ;Default attack distance
proj.attack.dist = 90 ;Default attack distance for projectiles
proj.doscale = 0     ;Set to 1 to scale projectiles too
head.pos = -5, -90   ;Approximate position of head
mid.pos = -5, -60    ;Approximate position of midsection
shadowoffset = 0     ;Number of pixels to vertically offset the shadow
draw.offset = 0,0    ;Player drawing offset in pixels (x, y)

[Velocity]
walk.fwd  = 2.4      ;Walk forward
walk.back = -2.1     ;Walk backward
run.fwd  = 4.8, 0    ;Run forward (x, y)
run.back = -4.5,-4   ;Hop backward (x, y)
jump.neu = 0,-9.6     ;Neutral jumping velocity (x, y)
jump.fwd = 4.2,-8.4   ;Jump forward Speed (x, y)
jump.back = -3.9,-8.4 ;Jump back Speed (x, y)
runjump.fwd = 4.5,-8.7   ;Running jump speeds (opt)
runjump.back = -4.2       ;.
airjump.neu = 0,-8.4      ;Air jump speeds (opt)
airjump.fwd = 4.2         ;.
airjump.back = -3.9       ;.

[Movement]
yaccel = .44         ;Vertical acceleration
stand.friction = .85  ;Friction coefficient when standing
crouch.friction = .82 ;Friction coefficient when crouching

;---------------------------------------------------------------------------
; Format:
; [Statedef STATENO]
; type = ?
; movetype = ?
; physics = ?
; juggle = ?
;
; [State STATENO, ?]
; type = ?
; ...

;---------------------------------------------------------------------------
; Lose by Time Over
; CNS difficulty: basic
[Statedef 170]
type = S
ctrl = 0
anim = 170
velset = 0,0

[State 170, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

;---------------------------------------------------------------------------
; Win state decider
; CNS difficulty: basic
[Statedef 180]
type = S

[State 180, 1]
type = ChangeState
trigger1 = Time = 0
value = 181

;---------------------------------------------------------------------------
; Win pose
; CNS difficulty: basic
[Statedef 181]
type = S
ctrl = 0
;anim = 181
velset = 0,0

[State 181, 1]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

;---------------------------------------------------------------------------
; Round initialization (override of common1.cns 5900)
; Sets bonus mode (fvar(11) = 2) so helpers spawn
[Statedef 5900]
type = S

[State 5900, 1]
type = VarRangeSet
trigger1 = roundsexisted = 0
value = 0

[State 5900, 2]
type = VarRangeSet
trigger1 = roundsexisted = 0
fvalue = 0

[State 5900, 3]
type = VarSet
trigger1 = 1
fvar(11) = 2

[State 5900, 4]
type = ChangeState
trigger1 = roundno = 1
value = 190

[State 5900, 5]
type = ChangeState
trigger1 = 1
value = 0

;---------------------------------------------------------------------------
; Introduction
; CNS difficulty: basic
[Statedef 191]
type = S
ctrl = 0
anim = 0
velset = 0,0

[State 191, 1] ;Change to stand state when done
type = ChangeState
trigger1 = RoundState = 2
trigger2 = Time = 360;Means when making an error
value = 0

;---------------------------------------------------------------------------
; Taunt
; CNS difficulty: easy
[Statedef 195]
type = S
ctrl = 0
anim = 195
velset = 0,0
movetype = I
physics = S
sprpriority = 2

[State 195, 1]
type = CtrlSet
trigger1 = Time = 40
value = 1

[State 195, 2]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

;---------------------------------------------------------------------------
; Example Attack
[Statedef 199]
type    = S                      ;State-type: S-stand, C-crouch, A-air, L-liedown, U-un changed (Def: ?)
movetype= A                      ;Move-type: A-attack, I-idle, H-gethit, U-un changed (Def: ?)
physics = S                      ;Physics: S-stand, C-crouch, A-air, N-assumed, U-un changed (Def: ?)
juggle  = 1                      ;Number of air juggle points move takes(Def: 0?)
;Commonly-used controllers:
velset = 0,0                     ;Set velocity (x,y) (Def: no change)
ctrl = 0                         ;Set ctrl (Def: no change)
anim = 199                       ;Change animation (Def: no change)
poweradd = 0                     ;Power to add (Def: 0)
sprpriority = 2                  ;Set layering priority to 2 (in front)

[State 199, 1]
type = PlaySnd
trigger1 = Time = 1
value = 0, 0

[State 199, 2]
type = HitDef
trigger1 = !movecontact
attr = S, NA                     ;Attribute: Standing, Normal Attack
damage = 0, 0                    ;Damage that move inflicts, guard damage
;getpower = aa, 0                ;(def:damage*Default.GetHit.LifeToPowerMul, aa/2)
;givepower = ab, 0               ;(def:damage*Default.GetHit.LifeToPowerMul, ab/2)
animtype = Light                 ;Animation type: Light, Medium, Heavy, Back (def: Light)
hitflag = MAF                    ;Flags of conditions that move can hit (def: MAF)
guardflag = MA                   ;Flags on how move is to be guarded against (def: no?)
priority = 4, Hit                ;Attack priority: 0 [least] to 7 [most] (def: 4)
;Hit/Miss/Dodge type (Def: Hit) <<<<<<<<<<< What? Mmm....
pausetime = 0, 0                 ;Time attacker pauses, time opponent shakes
sparkno = 0                      ;Spark anim no (Def: set above)
sparkxy = 0, 0                   ;X-offset for the "hit spark" rel. to p2, (Def: 0, 0)
;Y-offset for the spark rel. to p1
hitsound = 0, 0                  ;Sound to play on hit
guardsound = 0, 0                ;Sound to play on guard
ground.type = High               ;Type: High, Low, Trip (def: High)
ground.slidetime = 0             ;Time that the opponent slides back
ground.hittime  = 0              ;Time opponent is in hit state
ground.velocity = 0              ;Velocity at which opponent is pushed
air.hittime = 0                  ;Time before opponent regains control in air (def: same as ground.hittime?)
air.type = High                  ;Type: High, Low, Trip (def: same as ground.type)
air.velocity = 0, 0              ;X-velocity at which opponent is pushed,
airguard.velocity = 0, 0         ;Guard velocity in air (def: (air.xvel*1.5, air.yvel/2))
;Y-velocity at which opponent is pushed
fall = 1                         ;(def: 0)
fall.recover = 1                 ;(def: 0)
fall.animtype = Back             ;Animation type when "fall = 1" (def: Back)

[State 199, 3]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

