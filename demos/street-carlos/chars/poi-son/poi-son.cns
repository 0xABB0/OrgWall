triggerall = (!fvar(12) && alive) || fvar(12)
triggerall = fvar(11) = 2
triggerall = NumHelper(10000) = 0
triggerall = RoundState = 2
trigger1 = ctrl
trigger2 = (stateno != 0) && (stateno != 5900) && (stateno != [190,194])
