; HIT_LIEDEAD
[Statedef 5150]
type    = L
movetype= H
physics = N
sprpriority = -3

[State 5150, 1] ;Normal anim
type = ChangeAnim
triggerall = IsHelper
triggerall = Time = 0
triggerall = SelfAnimExist(5140)
trigger1 = (anim != [5111,5119]) && (anim != [5171,5179])
trigger2 = !SelfAnimExist(5140 + (anim % 10))
value = 5140

[State 5150, 3] ;Hit up type anim
type = ChangeAnim
trigger1 = IsHelper
trigger1 = Time = 0
trigger1 = (anim = [5111,5119]) || (anim = [5171,5179])
trigger1 = SelfAnimExist(5140 + (anim % 10))
value = 5140 + (anim % 10)

[State 5150, 4] ;Match over anim
type = ChangeAnim
persistent = 0
;triggerall = Time = 0
triggerall = IsHelper
triggerall = MatchOver = 1
triggerall = SelfAnimExist(anim+10)
trigger1 = Anim = 5140
trigger2 = Anim = [5140,5149]
value = anim+10

[State 5150, 5] ;Switch to 5110 if liedead anim does not exist
type = ChangeAnim
trigger1 = Time = 0
trigger1 = Anim != 5140
trigger1 = Anim != 5110
trigger1 = Anim != [5141,5159]
trigger1 = Anim != [5111,5119]
value = 5110

[State 0, 0]
type = DestroySelf
trigger1 = ishelper
trigger1 = Time = 60

[State 5150, 6] ;Friction
type = VelMul
trigger1 = 1
x = 0.85

[State 5150, 7] ;Friction
type = VelSet
trigger1 = Vel x < .05
persistent = 0
x = 0

[State 5150, 8]
type = NotHitBy
trigger1 = 1
value = SCA
time = 1

;---------------------------------------------------------------------------
; States that are always executed (use statedef -2)
;---------------------------------------------------------------------------
[Statedef -2]

[State -2, Root]
type = Palfx
trigger1 = fvar(11) = 2
time = 1
add = 80, 0, 80
ignorehitpause = 1

;---------------------------------------------------------------------------
[State -2]
type = DisplayToClipboard
trigger1 = 1
text = "var(10)= %d, var(11)= %d, var(12)= %d, var(13)= %d.\n"
params = var(10),var(11),var(12),var(13)

;---------------------------------------------------------------------------
[State -2]
type = AppendToClipboard
trigger1 = 1
text = "var(14)= %d, var(15)= %d."
params = var(14),var(15)

;---------------------------------------------------------------------------
[State 0, 0]
type = posadd
triggerall = AnimElem = 3
trigger1 = Anim = 20
trigger2 = Anim = 100
x = 10

[State 0, 0]
type = posadd
triggerall = AnimElem = 6
trigger1 = Anim = 20
trigger2 = Anim = 100
x = 20

[State 0, 0]
type = posadd
trigger1 = Anim = 21
trigger1 = AnimElem = 3
x = -20

[State 0, 0]
type = posadd
trigger1 = Anim = 21
trigger1 = AnimElem = 6
x = -10

;---------------------------------------------------------------------------
; States that are executed when in self's state file (use statedef -3)
;---------------------------------------------------------------------------
[Statedef -3]

;This controller plays a sound everytime KFM lands from a jump, or
;from his back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 40, 0

[State -3, Nothitby]
type = Nothitby
trigger1 = stateno = [5100,5101]
trigger2 = anim = [5090,5099]
trigger2 = (stateno = 5030) || (stateno = 5035) || (stateno = 5050) || (stateno = 5080)
value = SCA
time = 1

